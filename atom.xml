    <title>oracle建表和基本操作</title>
    <link href="http://example.com/2022/09/27/oracle%E5%BB%BA%E8%A1%A8%E5%92%8C%E5%9F%BA%E6%9C%AC%E6%93%8D%E4%BD%9C%E5%AE%9E%E9%AA%8C/"/>
    <id>http://example.com/2022/09/27/oracle%E5%BB%BA%E8%A1%A8%E5%92%8C%E5%9F%BA%E6%9C%AC%E6%93%8D%E4%BD%9C%E5%AE%9E%E9%AA%8C/</id>
    <published>2022-09-27T05:20:40.000Z</published>
    <updated>2022-09-30T03:44:51.071Z</updated>
    
    <content type="html"><![CDATA[<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/hint.css/2.4.1/hint.min.css"><h1 id="数据库基本操作"><a href="#数据库基本操作" class="headerlink" title="数据库基本操作"></a>数据库基本操作</h1><h2 id="Oracle基本命令"><a href="#Oracle基本命令" class="headerlink" title="Oracle基本命令"></a>Oracle基本命令</h2><h3 id="开始前的准备"><a href="#开始前的准备" class="headerlink" title="开始前的准备"></a>开始前的准备</h3><h4 id="以管理员身份登录sql"><a href="#以管理员身份登录sql" class="headerlink" title="以管理员身份登录sql"></a>以管理员身份登录sql</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line">sqlpuls <span class="operator">/</span>nolog</span><br></pre></td></tr></table></figure><h4 id="连接数据库"><a href="#连接数据库" class="headerlink" title="连接数据库"></a>连接数据库</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line">conn <span class="operator">/</span> <span class="keyword">as</span> sysdba</span><br></pre></td></tr></table></figure><h4 id="创建用户user6374-，密码user6374"><a href="#创建用户user6374-，密码user6374" class="headerlink" title="创建用户user6374 ，密码user6374"></a>创建用户user6374 ，密码user6374</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">create</span> <span class="keyword">user</span>  user6374 identified <span class="keyword">by</span> user6374 </span><br></pre></td></tr></table></figure><h4 id="查询数据字典"><a href="#查询数据字典" class="headerlink" title="查询数据字典"></a>查询数据字典</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">select</span> user_name <span class="keyword">from</span> dba_tables</span><br><span class="line"><span class="keyword">desc</span> dba_users</span><br></pre></td></tr></table></figure><h4 id="查询user6374"><a href="#查询user6374" class="headerlink" title="查询user6374"></a>查询user6374</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">select</span> username  <span class="keyword">from</span> dba_users</span><br></pre></td></tr></table></figure><h4 id="给user0923授权-赋予connect-resource-两个权限"><a href="#给user0923授权-赋予connect-resource-两个权限" class="headerlink" title="给user0923授权,赋予connect,resource 两个权限"></a>给user0923授权,赋予connect,resource 两个权限</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">grant</span> <span class="keyword">connect</span>,resource <span class="keyword">to</span> user6374 </span><br></pre></td></tr></table></figure><h4 id="以user6374帐号登陆"><a href="#以user6374帐号登陆" class="headerlink" title="以user6374帐号登陆"></a>以user6374帐号登陆</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line">conn user6374<span class="operator">/</span>user6374   </span><br></pre></td></tr></table></figure><h4 id="展示用户"><a href="#展示用户" class="headerlink" title="展示用户"></a>展示用户</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">show</span> <span class="keyword">user</span></span><br></pre></td></tr></table></figure><h4 id="建表"><a href="#建表" class="headerlink" title="建表"></a>建表</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">create</span> <span class="keyword">table</span> tbl_student(</span><br><span class="line"> stu_id <span class="type">int</span> <span class="keyword">primary</span> key,</span><br><span class="line"> stu_name varchar2(<span class="number">30</span>) <span class="keyword">not</span> <span class="keyword">null</span>,</span><br><span class="line"> stu_sex <span class="type">char</span>(<span class="number">1</span>) <span class="keyword">default</span> <span class="string">&#x27;m&#x27;</span>,</span><br><span class="line"> stu_birth <span class="type">date</span> <span class="keyword">not</span> <span class="keyword">null</span></span><br><span class="line">)</span><br></pre></td></tr></table></figure><h4 id="查看表结构"><a href="#查看表结构" class="headerlink" title="查看表结构"></a>查看表结构</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">desc</span> tbl_student</span><br></pre></td></tr></table></figure><h4 id="查看用户创建的表的信息的数据字典"><a href="#查看用户创建的表的信息的数据字典" class="headerlink" title="查看用户创建的表的信息的数据字典"></a>查看用户创建的表的信息的数据字典</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">desc</span> user_tables</span><br></pre></td></tr></table></figure><h4 id="查看user-tables-确认表的存在"><a href="#查看user-tables-确认表的存在" class="headerlink" title="查看user_tables 确认表的存在"></a>查看user_tables 确认表的存在</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">select</span> table_name <span class="keyword">from</span> user_tables</span><br><span class="line"><span class="keyword">select</span> <span class="built_in">count</span>(<span class="operator">*</span>) <span class="keyword">from</span> user_tables</span><br></pre></td></tr></table></figure><h4 id="查看user-constraints确认约束的存在"><a href="#查看user-constraints确认约束的存在" class="headerlink" title="查看user_constraints确认约束的存在"></a>查看user_constraints确认约束的存在</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">desc</span> user_constraints <span class="operator">/</span><span class="operator">/</span>约束表</span><br><span class="line"><span class="keyword">select</span> owner table_name,constraint_name.constraint_type <span class="keyword">from</span> user_constraints<span class="operator">/</span><span class="operator">/</span>查询本表约束</span><br><span class="line"><span class="keyword">select</span> <span class="built_in">count</span>(<span class="operator">*</span>) <span class="keyword">from</span> user_constraints<span class="operator">/</span><span class="operator">/</span>查询约束条数</span><br></pre></td></tr></table></figure><hr><h3 id="增删改查实践"><a href="#增删改查实践" class="headerlink" title="增删改查实践"></a>增删改查实践</h3><h4 id="创建一个序列"><a href="#创建一个序列" class="headerlink" title="创建一个序列"></a>创建一个序列</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">create</span> sequence seq_stu_id</span><br></pre></td></tr></table></figure><h4 id="显示用户序列表"><a href="#显示用户序列表" class="headerlink" title="显示用户序列表"></a>显示用户序列表</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">desc</span> user_sequences</span><br></pre></td></tr></table></figure><h4 id="显示序列"><a href="#显示序列" class="headerlink" title="显示序列"></a>显示序列</h4> <figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">select</span> sequence_name,min_value,max_value <span class="keyword">from</span> user_sequences</span><br></pre></td></tr></table></figure><h4 id="插入一条数据"><a href="#插入一条数据" class="headerlink" title="插入一条数据"></a>插入一条数据</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">insert</span> <span class="keyword">into</span> tbl_student <span class="keyword">values</span>(seq_stu_id.nextval,<span class="string">&#x27;mary&#x27;</span>,<span class="keyword">default</span>,sysdate)<span class="operator">/</span><span class="operator">/</span>id为<span class="number">2</span>，姓名marry，生日为系统时间</span><br><span class="line"><span class="keyword">insert</span> <span class="keyword">into</span> tbl_student <span class="keyword">values</span>(seq_stu_id.nextval,<span class="string">&#x27;mike&#x27;</span>,<span class="string">&#x27;m&#x27;</span>,to_date(<span class="string">&#x27;2002-10-29&#x27;</span>),<span class="string">&#x27;yyyy-mm-dd&#x27;</span>)</span><br></pre></td></tr></table></figure><h4 id="查询表"><a href="#查询表" class="headerlink" title="查询表"></a>查询表</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">select</span> <span class="operator">*</span> <span class="keyword">from</span> tbl_student</span><br><span class="line"><span class="keyword">select</span> stu_id,stu_name <span class="keyword">from</span> tbl_student</span><br></pre></td></tr></table></figure><h4 id="修改表"><a href="#修改表" class="headerlink" title="修改表"></a>修改表</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">update</span> tbl_student <span class="keyword">set</span> stu_name<span class="operator">=</span><span class="string">&#x27;tom&#x27;</span> <span class="keyword">where</span> stu_id<span class="operator">=</span><span class="number">2</span> <span class="operator">/</span><span class="operator">/</span>修改marry的名字为tom</span><br><span class="line"><span class="keyword">update</span> tbl_student <span class="keyword">set</span> stu_name<span class="operator">=</span><span class="string">&#x27;john&#x27;</span>,stu_sex<span class="operator">=</span><span class="string">&#x27;f&#x27;</span> <span class="keyword">where</span> stu_id<span class="operator">=</span><span class="string">&#x27;3&#x27;</span><span class="operator">/</span><span class="operator">/</span>修改id为<span class="number">3</span>的人姓名性别</span><br></pre></td></tr></table></figure><h4 id="删除记录"><a href="#删除记录" class="headerlink" title="删除记录"></a>删除记录</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">delete</span> <span class="keyword">from</span> tbl_student <span class="keyword">where</span> stu_id<span class="operator">=</span><span class="number">2</span> <span class="operator">/</span><span class="operator">/</span>删除id为<span class="number">2</span>的数据</span><br><span class="line"><span class="keyword">delete</span> <span class="keyword">from</span> tbl_student <span class="operator">/</span><span class="operator">/</span>全删除</span><br><span class="line"><span class="keyword">drop</span> <span class="keyword">table</span> tbl_student<span class="operator">/</span><span class="operator">/</span>删除表</span><br></pre></td></tr></table></figure><h4 id="退出系统，删除用户"><a href="#退出系统，删除用户" class="headerlink" title="退出系统，删除用户"></a>退出系统，删除用户</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br></pre></td><td class="code"><pre><span class="line">exit <span class="operator">/</span><span class="operator">/</span>退出</span><br><span class="line">conn <span class="operator">/</span> <span class="keyword">as</span> sysdba <span class="operator">/</span><span class="operator">/</span>以管理员身登录</span><br><span class="line"><span class="keyword">drop</span> <span class="keyword">user</span> user6374 cascade <span class="operator">/</span><span class="operator">/</span>删除用户及所有内容</span><br></pre></td></tr></table></figure><h3 id="PL-x2F-sql操作"><a href="#PL-x2F-sql操作" class="headerlink" title="PL&#x2F;sql操作"></a>PL&#x2F;sql操作</h3><h4 id="建用户名和密码oracle-oracle"><a href="#建用户名和密码oracle-oracle" class="headerlink" title="建用户名和密码oracle ,oracle"></a>建用户名和密码oracle ,oracle</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">create</span> <span class="keyword">user</span> username identified <span class="keyword">by</span> password</span><br></pre></td></tr></table></figure><h4 id="授权给用户"><a href="#授权给用户" class="headerlink" title="授权给用户;"></a>授权给用户;</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">grant</span> <span class="keyword">connect</span>,resource,dba <span class="keyword">to</span> username</span><br></pre></td></tr></table></figure><h4 id="进入"><a href="#进入" class="headerlink" title="进入"></a>进入</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">connect</span> username<span class="operator">/</span>password</span><br></pre></td></tr></table></figure><h4 id="输出语句"><a href="#输出语句" class="headerlink" title="输出语句"></a>输出语句</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line">dbms_output_putline(<span class="string">&#x27;输出的内容&#x27;</span>)</span><br></pre></td></tr></table></figure><h4 id="显示PL-x2F-sql输出结果"><a href="#显示PL-x2F-sql输出结果" class="headerlink" title="显示PL&#x2F;sql输出结果"></a>显示PL&#x2F;sql输出结果</h4><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">set</span> serveroutput <span class="keyword">on</span></span><br></pre></td></tr></table></figure>]]></content>
    
    
      
      
